POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com
CHAIN_ID=137

# Wallet / CLOB auth
PRIVATE_KEY=
FUNDER_ADDRESS=
TRACKING_USER_ADDRESS=
SIGNATURE_TYPE=1

# Bot mode
LIVE_TRADING=false
PAPER_BALANCE=100.0
RUN_ONCE=false

# Strategy
SECONDS_BEFORE_RESOLUTION=120
MIN_CONFIDENCE_PRICE=0.80
MAX_WORST_PRICE=0.985
TRADE_SIZE_USD=10
MIN_LIQUIDITY_ON_BEST_LEVEL=25
POLL_INTERVAL_SECONDS=0.5
ONLY_ONE_TRADE_PER_MARKET=true
SKIP_SECONDS_DELAYED_MARKETS=true
BINANCE_STALE_AFTER_SECONDS=5
BINANCE_VOLATILITY_LOOKBACK_SECONDS=120

# Post-trade tracking
AUTO_SETTLE_PAPER=true
AUTO_SETTLE_LIVE=true
REPORT_EVERY_LOOP=true

# Storage
JOURNAL_PATH=journal.json
REPORTS_DIR=reports

# Last-minute monitoring diagnostics
TOUCHLOG_ENABLED=true
TOUCHLOG_PATH=reports/touches.json
